# Local dev: proxied to the Express server (see src/setupProxy.js)
REACT_APP_BACKEND_URL=http://localhost:5001

# Production (Vercel): set this in the Vercel dashboard to your deployed backend URL, e.g.
# REACT_APP_BACKEND_URL=https://your-backend.onrender.com
# Backend .env vars (JWT, Cloudinary, etc.) belong on the backend host — not on Vercel.
